generator client {
  provider = "prisma-client-js"
  output   = "../src/lib/prisma/generated"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  Admin_ID Int        @id @default(autoincrement())
  User_ID  Int        @unique(map: "User_ID")
  USERS    USERS      @relation(fields: [User_ID], references: [User_ID], onDelete: Cascade, map: "Admin_ibfk_1")
  SCHEDULE SCHEDULE[]
}

model COURSES {
  Course_ID         Int            @id @default(autoincrement())
  Course_Number     Int?
  Course_Section    Decimal?       @db.Decimal(4, 1)
  Course_Title      String?        @db.VarChar(255)
  Course_Instructor String?        @db.VarChar(255)
  Enrolled_Count    Int?           @default(0)
  ENROLLMENTS       ENROLLMENTS[]
  TUTOR_COURSE      TUTOR_COURSE[]
}

model ENROLLMENTS {
  Enrollment_ID      Int                  @id @default(autoincrement())
  User_ID            Int
  Tutor_ID           Int?
  Course_ID          Int
  Total_Enrollment   Int?                 @default(0)
  USERS              USERS                @relation(fields: [User_ID], references: [User_ID], onDelete: Cascade, map: "ENROLLMENTS_ibfk_1")
  Tutor              Tutor?               @relation(fields: [Tutor_ID], references: [Tutor_ID], map: "ENROLLMENTS_ibfk_2")
  COURSES            COURSES              @relation(fields: [Course_ID], references: [Course_ID], onDelete: Cascade, map: "ENROLLMENTS_ibfk_3")
  STUDY_BUDDY_GROUPS STUDY_BUDDY_GROUPS[]
  TUTORING_SESSION   TUTORING_SESSION[]

  @@index([Course_ID], map: "Course_ID")
  @@index([Tutor_ID], map: "Tutor_ID")
  @@index([User_ID], map: "User_ID")
}

model SCHEDULE {
  Schedule_ID        Int                @id @default(autoincrement())
  Admin_ID           Int
  Availability_ID    Int
  Has_Worked         Boolean?           @default(false)
  Admin              Admin              @relation(fields: [Admin_ID], references: [Admin_ID], onDelete: Cascade, map: "SCHEDULE_ibfk_1")
  TUTOR_AVAILABILITY TUTOR_AVAILABILITY @relation(fields: [Availability_ID], references: [Availability_ID], onDelete: Cascade, map: "SCHEDULE_ibfk_2")

  @@index([Admin_ID], map: "Admin_ID")
  @@index([Availability_ID], map: "Availability_ID")
}

model STUDY_BUDDY_GROUPS {
  Group_ID      Int         @id @default(autoincrement())
  User_ID       Int
  Tutor_ID      Int?
  Enrollment_ID Int
  Is_Accepted   Boolean?    @default(false)
  Has_Tutor     Boolean?    @default(false)
  Group_Members Int?        @default(0)
  USERS         USERS       @relation(fields: [User_ID], references: [User_ID], onDelete: Cascade, map: "STUDY_BUDDY_GROUPS_ibfk_1")
  Tutor         Tutor?      @relation(fields: [Tutor_ID], references: [Tutor_ID], map: "STUDY_BUDDY_GROUPS_ibfk_2")
  ENROLLMENTS   ENROLLMENTS @relation(fields: [Enrollment_ID], references: [Enrollment_ID], onDelete: Cascade, map: "STUDY_BUDDY_GROUPS_ibfk_3")

  @@index([Enrollment_ID], map: "Enrollment_ID")
  @@index([Tutor_ID], map: "Tutor_ID")
  @@index([User_ID], map: "User_ID")
}

model Student {
  User_ID Int      @id
  GPA     Decimal? @db.Decimal(4, 3)
  USERS   USERS    @relation(fields: [User_ID], references: [User_ID], onDelete: Cascade, map: "Student_ibfk_1")
}

model TUTORING_SESSION {
  Session_ID      Int         @id @default(autoincrement())
  User_ID         Int
  Tutor_ID        Int
  Enrollment_ID   Int
  Session_Date    DateTime?   @db.Date
  Session_Time    DateTime?   @db.Timestamp(0)
  Session_Loc     String?     @db.VarChar(255)
  Students_Booked Int?        @default(0)
  Session_Max     Int?        @default(0)
  USERS           USERS       @relation(fields: [User_ID], references: [User_ID], onDelete: Cascade, map: "TUTORING_SESSION_ibfk_1")
  Tutor           Tutor       @relation(fields: [Tutor_ID], references: [Tutor_ID], onDelete: Cascade, map: "TUTORING_SESSION_ibfk_2")
  ENROLLMENTS     ENROLLMENTS @relation(fields: [Enrollment_ID], references: [Enrollment_ID], onDelete: Cascade, map: "TUTORING_SESSION_ibfk_3")

  @@index([Enrollment_ID], map: "Enrollment_ID")
  @@index([Tutor_ID], map: "Tutor_ID")
  @@index([User_ID], map: "User_ID")
}

model TUTOR_AVAILABILITY {
  Availability_ID Int        @id @default(autoincrement())
  Tutor_ID        Int
  Date_Requested  DateTime?  @db.Date
  Times_Requested DateTime?  @db.Timestamp(0)
  Is_Approved     Boolean?   @default(false)
  SCHEDULE        SCHEDULE[]
  Tutor           Tutor      @relation(fields: [Tutor_ID], references: [Tutor_ID], onDelete: Cascade, map: "TUTOR_AVAILABILITY_ibfk_1")

  @@index([Tutor_ID], map: "Tutor_ID")
}

model Tutor {
  Tutor_ID           Int                  @id @default(autoincrement())
  User_ID            Int                  @unique(map: "User_ID")
  ENROLLMENTS        ENROLLMENTS[]
  STUDY_BUDDY_GROUPS STUDY_BUDDY_GROUPS[]
  TUTORING_SESSION   TUTORING_SESSION[]
  TUTOR_AVAILABILITY TUTOR_AVAILABILITY[]
  TUTOR_COURSE       TUTOR_COURSE[]
  USERS              USERS                @relation(fields: [User_ID], references: [User_ID], onDelete: Cascade, map: "Tutor_ibfk_1")
}

model USERS {
  User_ID            Int                  @id @default(autoincrement())
  Name               String               @db.VarChar(255)
  Email              String               @unique(map: "Email") @db.VarChar(255)
  Is_Admin           Boolean?             @default(false)
  Is_Tutor           Boolean?             @default(false)
  Is_Student         Boolean?             @default(true)
  Admin              Admin?
  ENROLLMENTS        ENROLLMENTS[]
  STUDY_BUDDY_GROUPS STUDY_BUDDY_GROUPS[]
  Student            Student?
  TUTORING_SESSION   TUTORING_SESSION[]
  Tutor              Tutor?
}

model TUTOR_COURSE {
  TutorCourseID Int     @id @default(autoincrement())
  Tutor_ID      Int
  Course_ID     Int
  Tutor         Tutor   @relation(fields: [Tutor_ID], references: [Tutor_ID], onDelete: Cascade, map: "TUTOR_COURSE_ibfk_1")
  COURSES       COURSES @relation(fields: [Course_ID], references: [Course_ID], onDelete: Cascade, map: "TUTOR_COURSE_ibfk_2")

  @@index([Course_ID], map: "Course_ID")
  @@index([Tutor_ID], map: "Tutor_ID")
}
